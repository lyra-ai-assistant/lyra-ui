{
  "name": "lyra-ui",
  "version": "0.1.0",
  "description": "A virtual assistant for GNU/Linux",
  "repository": "https://github.com/AndresMpa/lyra",
  "homepage": "https://github.com/AndresMpa/lyra",
  "author": "AndresMpa <ing.andres.m.prieto@gmail.com>, xcerock <xcerock@gmail.com>",
  "license": "MIT",
  "main": "main.js",
  "keywords": [
    "IA",
    "Virtual",
    "Assistant",
    "GNU/Linux"
  ],
  "scripts": {
    "start": "electron ./main.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "Lyra: Your Cosmic Companion",
    "productName": "lyra",
    "directories": {
      "output": "../dist",
      "buildResources": "assets"
    },
    "files": [
      "assets/**/*",
      "config/**/*",
      "eventHandlers/**/*",
      "index.html",
      "main.js",
      "OS/**/*",
      "preloader/**/*",
      "styles/**/*",
      "templates/**/*",
      "utils/**/*"
    ],
    "linux": {
      "target": [
        "tar.gz"
      ],
      "category": "Utility",
      "icon": "assets/app/256x256.png"
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "markdown-it": "^14.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.2",
    "electron-builder": "^24.13.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
